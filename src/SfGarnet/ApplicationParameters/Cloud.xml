<?xml version="1.0" encoding="utf-8"?>
<!--
  Cloud / multi-node on-premise production cluster.
  One Garnet node per SF node (InstanceCount = -1), sharded across all primaries with
  1 replica each, AOF on for durability + replica resync. Size MemorySize to the node SKU.
  Set SfGarnet_ClusterUsername / SfGarnet_ClusterPassword at deploy time to secure the gossip bus.
-->
<Application xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" Name="fabric:/SfGarnet" xmlns="http://schemas.microsoft.com/2011/01/fabric">
  <Parameters>
    <Parameter Name="SfGarnet_Mode" Value="Cluster" />
    <Parameter Name="GarnetService_InstanceCount" Value="-1" />
    <Parameter Name="GarnetService_MemorySize" Value="4g" />
    <Parameter Name="GarnetService_EnableAof" Value="true" />
    <Parameter Name="GarnetService_CleanClusterConfig" Value="true" />
    <Parameter Name="ClusterManager_ReplicaCount" Value="1" />
    <Parameter Name="ClusterManager_ReconcileIntervalSeconds" Value="15" />
    <Parameter Name="SfGarnet_ClusterUsername" Value="" />
    <Parameter Name="SfGarnet_ClusterPassword" Value="" />
  </Parameters>
</Application>