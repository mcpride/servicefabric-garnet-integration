<?xml version="1.0" encoding="utf-8"?>
<!--
  Connects to a remote (cloud or on-premise multi-node) cluster and deploys Cloud params.
  Fill in the connection endpoint and security settings for your cluster. Examples:

  Unsecured:
    <ClusterConnectionParameters ConnectionEndpoint="mycluster.example.com:19000" />

  X509 (certificate) secured:
    <ClusterConnectionParameters
        ConnectionEndpoint="mycluster.example.com:19000"
        X509Credential="true"
        ServerCertThumbprint="<server-cert-thumbprint>"
        FindType="FindByThumbprint"
        FindValue="<client-cert-thumbprint>"
        StoreLocation="CurrentUser"
        StoreName="My" />

  Azure AD secured:
    <ClusterConnectionParameters
        ConnectionEndpoint="mycluster.example.com:19000"
        AzureActiveDirectory="true"
        ServerCertThumbprint="<server-cert-thumbprint>" />
-->
<PublishProfile xmlns="http://schemas.microsoft.com/2015/05/fabrictools">
  <ClusterConnectionParameters ConnectionEndpoint="mycluster.example.com:19000" />
  <ApplicationParameterFile Path="..\ApplicationParameters\Cloud.xml" />
</PublishProfile>
